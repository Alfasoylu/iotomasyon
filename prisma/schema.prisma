generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum InterestStatus {
  NEW
  WAITING_STOCK
  CONTACTED
  QUOTED
  WON
  LOST
  CANCELLED
}

enum InterestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum CustomerStatus {
  NEW
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum InterestStage {
  INTERESTED
  PRICE_SENT
  NEGOTIATING
  WAITING
  ORDERED
  CANCELLED
}

enum NoteType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
  QUOTE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  WON
  LOST
  ACCEPTED
  DECLINED
}

enum OutreachStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum RecipientStatus {
  PENDING
  SENT
  REPLIED
  QUOTED
  WON
  LOST
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  passwordHash             String
  name                     String
  role                     UserRole           @default(ADMIN)
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  productsCreated          Product[]          @relation("CreatedProducts")
  notesCreated             Note[]
  interestsCreated         ProductInterest[]  @relation("CreatedInterests")
  interestsOwned           ProductInterest[]  @relation("AssignedInterests")
  tasksCreated             FollowUpTask[]     @relation("CreatedTasks")
  tasksOwned               FollowUpTask[]     @relation("AssignedTasks")
  quotesCreated            Quote[]
  categoryInterestsCreated CategoryInterest[] @relation("CreatedCategoryInterests")
  campaignsCreated         OutreachCampaign[] @relation("CreatedCampaigns")
  customersOwned           Customer[]         @relation("OwnedCustomers")
}

model ProductCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  parentId    String?
  parent      ProductCategory?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]  @relation("CategoryTree")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  products    Product[]
  interests   CategoryInterest[]
  campaigns   OutreachCampaign[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id              String           @id @default(cuid())
  sku             String           @unique
  name            String
  category        String?
  categoryId      String?
  brand           String?
  model           String?
  stockQuantity   Int              @default(0)
  minimumStock    Int              @default(0)
  location        String?
  description     String?
  isActive        Boolean          @default(true)
  createdById     String?
  createdBy       User?            @relation("CreatedProducts", fields: [createdById], references: [id], onDelete: SetNull)
  productCategory ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  interests       ProductInterest[]
  notes           Note[]
  tasks           FollowUpTask[]
  quoteItems      QuoteItem[]
  campaigns       OutreachCampaign[]

  @@index([name])
  @@index([category])
  @@index([categoryId])
  @@index([stockQuantity, minimumStock])
}

model Customer {
  id                String             @id @default(cuid())
  name              String
  phone             String?
  whatsapp          String?
  email             String?
  company           String?
  status            CustomerStatus     @default(NEW)
  country           String?
  customerNotes     String?            @map("notes")
  customerType      String?
  city              String?
  district          String?
  address           String?
  taxOffice         String?
  taxNumber         String?
  source            String?
  ownedById         String?
  isActive          Boolean            @default(true)
  lastContactedAt   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner               User?              @relation("OwnedCustomers", fields: [ownedById], references: [id], onDelete: SetNull)
  interests           ProductInterest[]
  categoryInterests   CategoryInterest[]
  timelineEntries     Note[]
  tasks               FollowUpTask[]
  quotes              Quote[]
  outreachRecipients  OutreachRecipient[]

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([ownedById])
  @@index([source])
}

model CategoryInterest {
  id          String          @id @default(cuid())
  customerId  String
  categoryId  String
  stage       InterestStage   @default(INTERESTED)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById String?
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation("CreatedCategoryInterests", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([customerId, categoryId])
  @@index([customerId])
  @@index([categoryId])
}

model ProductInterest {
  id              String           @id @default(cuid())
  customerId      String
  productId       String
  quantity        Int              @default(1) @map("quantityRequested")
  quotedPrice     Decimal?
  currency        String           @default("TRY")
  stage           InterestStage    @default(INTERESTED)
  interestNotes   String?          @map("note")
  targetPrice     Decimal?
  priority        InterestPriority @default(NORMAL)
  status          InterestStatus   @default(NEW)
  followUpAt      DateTime?
  lastContactedAt DateTime?
  closedAt        DateTime?
  source          String?
  createdById     String?
  assignedToId    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("CreatedInterests", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("AssignedInterests", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes           Note[]

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([priority])
  @@index([followUpAt])
  @@index([stage])
}

model Note {
  id          String           @id @default(cuid())
  content     String
  type        NoteType         @default(NOTE)
  customerId  String?
  productId   String?
  interestId  String?
  createdById String?
  createdAt   DateTime         @default(now())
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  interest    ProductInterest? @relation(fields: [interestId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([productId])
  @@index([interestId])
  @@index([createdAt])
}

model FollowUpTask {
  id           String       @id @default(cuid())
  title        String
  description  String?      @map("details")
  dueDate      DateTime?    @map("dueAt")
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  completedAt  DateTime?
  customerId   String?
  productId    String?
  assignedToId String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([priority])
}

model Quote {
  id            String      @id @default(cuid())
  customerId    String
  quoteNumber   String      @unique
  status        QuoteStatus @default(DRAFT)
  notes         String?
  validityDate  DateTime?
  sentAt        DateTime?
  subtotal      Decimal     @default(0)
  discountTotal Decimal     @default(0)
  taxTotal      Decimal     @default(0)
  total         Decimal     @default(0)
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items              QuoteItem[]
  outreachRecipients OutreachRecipient[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([validityDate])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal
  currency    String   @default("TRY")
  discount    Decimal  @default(0)
  tax         Decimal  @default(0)
  total       Decimal  @default(0)
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
}

model OutreachCampaign {
  id          String              @id @default(cuid())
  productId   String?
  categoryId  String?
  message     String
  offerText   String?
  price       Decimal?
  currency    String              @default("TRY")
  status      OutreachStatus      @default(DRAFT)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  product     Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  category    ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?               @relation("CreatedCampaigns", fields: [createdById], references: [id], onDelete: SetNull)
  recipients  OutreachRecipient[]

  @@index([productId])
  @@index([categoryId])
  @@index([createdAt])
}

model OutreachRecipient {
  id         String           @id @default(cuid())
  campaignId String
  customerId String
  phone      String?
  status     RecipientStatus  @default(PENDING)
  sentAt     DateTime?
  repliedAt  DateTime?
  quoteId    String?
  wonAmount  Decimal?
  createdAt  DateTime         @default(now())
  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quote      Quote?           @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
  @@index([quoteId])
}
