generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SALES
  OPERATIONS
  MARKETPLACE_OPERATOR
  CUSTOM
}

enum InterestStatus {
  NEW
  WAITING_STOCK
  CONTACTED
  QUOTED
  WON
  LOST
  CANCELLED
}

enum InterestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum CustomerStatus {
  NEW
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum InterestStage {
  INTERESTED
  PRICE_SENT
  NEGOTIATING
  WAITING
  ORDERED
  CANCELLED
}

enum NoteType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
  QUOTE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  WON
  LOST
  ACCEPTED
  DECLINED
}

enum QuoteCurrencyMode {
  USD
  TRY
  BOTH
}

enum OutreachStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum CustomerType {
  TOPTAN
  PERAKENDE
  SITE_YONETICISI
  GUVENLIK_SIRKETI
  MAGAZA
  ONLINE_SATICI
  CUSTOM
}

enum StockSource {
  MANUAL
  XML
  API
  IMPORT
}

enum XmlSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  ERROR
}

enum MarketplacePlatform {
  TRENDYOL
  HEPSIBURADA
  N11
  PTTAVM
  KOCTAS
  TEKNOSA
  TEMU
  CUSTOM
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  UNKNOWN
}

enum StockConfidence {
  HIGH
  MEDIUM
  LOW
}

// Phase 11A — Product classification
enum ProductKind {
  MAIN_STOCK      // physical inventory product
  LISTING_PACKAGE // marketplace listing / variant / bundle product
}

model ProductAttribute {
  id                String                       @id @default(cuid())
  name              String                       @unique
  createdAt         DateTime                     @default(now())
  products          ProductAttributeAssignment[]
  customerInterests CustomerAttributeInterest[]

  @@index([name])
}

model ProductAttributeAssignment {
  productId   String
  attributeId String
  createdAt   DateTime         @default(now())
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
}

model CustomerAttributeInterest {
  customerId  String
  attributeId String
  createdAt   DateTime         @default(now())
  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([customerId, attributeId])
  @@index([customerId])
  @@index([attributeId])
}

enum RecipientStatus {
  PENDING
  SENT
  REPLIED
  QUOTED
  WON
  LOST
}

// ── RBAC models ─────────────────────────────────────────────────

// System and custom role metadata + default permission mapping.
// key must match a UserRole enum value exactly.
// isSystem=true rows cannot be deleted via admin UI.
model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

// Canonical permission registry.
// Dangerous permissions (migrations.approve, destructiveActions.approve)
// must never appear in RolePermission rows — UserPermission only.
model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  name            String
  category        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([category])
}

// Default permissions per role.
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Per-user permission overrides.
// granted=true  → explicit grant  (overrides role defaults)
// granted=false → explicit deny   (overrides role defaults and grants)
// Dangerous permissions: only path to access — no role default applies.
model UserPermission {
  userId       String
  permissionId String
  granted      Boolean
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  passwordHash             String
  name                     String
  role                     UserRole           @default(ADMIN)
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  // RBAC — no new column; relation only
  userPermissions          UserPermission[]
  // existing relations unchanged
  productsCreated          Product[]          @relation("CreatedProducts")
  stockCountedProducts     Product[]          @relation("StockCountedBy")
  notesCreated             Note[]
  interestsCreated         ProductInterest[]  @relation("CreatedInterests")
  interestsOwned           ProductInterest[]  @relation("AssignedInterests")
  tasksCreated             FollowUpTask[]     @relation("CreatedTasks")
  tasksOwned               FollowUpTask[]     @relation("AssignedTasks")
  quotesCreated            Quote[]
  categoryInterestsCreated CategoryInterest[] @relation("CreatedCategoryInterests")
  campaignsCreated         OutreachCampaign[] @relation("CreatedCampaigns")
  customersOwned           Customer[]         @relation("OwnedCustomers")
  capitalConfigs           CapitalConfig[]
  marketplaceListings      MarketplaceListing[]           @relation("ListingResponsible")
  marketplaceMappings      MarketplaceProductMapping[]    @relation("MappingCreatedBy")
  questionActionLogs       MarketplaceQuestionActionLog[] @relation("QuestionActionUser")
  returnActionLogs         MarketplaceReturnActionLog[]   @relation("ReturnActionUser")
  quoteTemplates           QuoteTemplate[]                @relation("TemplatesCreated")
  marketplacePolicies      MarketplacePlatformPolicy[]    @relation("PolicyUpdatedBy")
}

model ProductCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  parentId    String?
  parent      ProductCategory?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]  @relation("CategoryTree")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  products    Product[]
  interests   CategoryInterest[]
  campaigns   OutreachCampaign[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id              String           @id @default(cuid())
  sku             String           @unique
  barcode         String?          @unique
  name            String
  imageUrl        String?
  category        String?
  categoryId      String?
  brand           String?
  model           String?
  supplier        String?
  stockQuantity   Int              @default(0)
  minimumStock    Int              @default(0)
  reorderLeadTime Int?
  stockSource         StockSource?
  stockConfidence     StockConfidence?
  lastStockSyncAt     DateTime?
  lastStockCountById  String?
  lastStockCountBy    User?            @relation("StockCountedBy", fields: [lastStockCountById], references: [id], onDelete: SetNull)
  location            String?
  description         String?
  isActive            Boolean          @default(true)
  shippingCost             Decimal?
  shippingCostOverride     Decimal?
  marketplaceCommission    Decimal?
  marketplaceCommissionOverride Decimal?
  importDate          DateTime?
  importQuantity      Int?
  importUnitCostUsd   Decimal?
  inventoryCountDate  DateTime?
  inventoryCountStock Int?
  // Phase 8 — Profitability Engine
  unitCostTry              Decimal?
  sellingPriceTry          Decimal?
  wholesalePriceTry        Decimal?
  marketplacePriceTry      Decimal?
  packagingCost            Decimal?
  vatRate                  Decimal?
  paymentFeeRate           Decimal?
  returnReserveRate        Decimal?
  // Phase 9 — Sales Potential Engine
  onlineSalesPotential     Int?
  wholesaleSalesPotential  Int?
  installerSalesPotential  Int?
  // Phase 11 — XML Sync override protection
  xmlLocked                Boolean  @default(false)
  // Phase 11A — XML import tracking
  xmlImported              Boolean  @default(false)
  // Phase 11A — Product classification
  productKind              ProductKind @default(MAIN_STOCK)
  mainProductId            String?     // for LISTING_PACKAGE → main stock product
  mainProduct              Product?    @relation("ProductHierarchy", fields: [mainProductId], references: [id], onDelete: SetNull)
  variantProducts          Product[]   @relation("ProductHierarchy")
  // Phase 16 — USD cost for import-priced products (do NOT remove unitCostTry)
  unitCostUsd              Decimal?
  // Phase 11C — Import decision inputs
  weightKg                 Decimal?
  customsRatePct           Decimal?
  shippingMethodPref       String?
  // Phase 31 — RMB-first import economics
  sourceCostRmb            Decimal? @db.Decimal(15,2) // Purchase cost in RMB/CNY
  importPaymentFeePct      Decimal? @db.Decimal(5,2)  // Payment commission % (e.g. 3.0)
  createdById     String?
  createdBy       User?            @relation("CreatedProducts", fields: [createdById], references: [id], onDelete: SetNull)
  productCategory ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  interests            ProductInterest[]
  notes                Note[]
  tasks                FollowUpTask[]
  quoteItems           QuoteItem[]
  campaigns            OutreachCampaign[]
  attributeAssignments ProductAttributeAssignment[]
  marketplaceListings  MarketplaceListing[]
  marketplaceMappings  MarketplaceProductMapping[]
  quoteTemplateItems   QuoteTemplateItem[]            @relation("TemplateItems")
  // Phase 11A — multi-image support
  images               ProductImage[]
  // Phase 11A — XML source data
  xmlData              XmlProductData?
  // Phase 20 — supplier links
  supplierLinks        SupplierProduct[]
  // Phase 26 — Trendyol sales records
  trendyolSalesRecords TrendyolSalesRecord[]
  // Phase 28 — Owner-only private intelligence (EXECUTIVE_READ only)
  privateNote          String?
  // Phase 29 — Trendyol return/claim records
  trendyolReturnRecords TrendyolReturnRecord[]

  @@index([name])
  @@index([barcode])
  @@index([category])
  @@index([categoryId])
  @@index([supplier])
  @@index([stockSource])
  @@index([stockConfidence])
  @@index([lastStockCountById])
  @@index([stockQuantity, minimumStock])
  @@index([mainProductId])
  @@index([productKind])
}

model Customer {
  id                String             @id @default(cuid())
  name              String
  phone             String?
  whatsapp          String?
  email             String?
  company           String?
  status            CustomerStatus     @default(NEW)
  country           String?
  customerNotes         String?            @map("notes")
  customerType          CustomerType?
  monthlySalesPotential Decimal?
  platformNotes         String?
  city              String?
  district          String?
  address           String?
  taxOffice         String?
  taxNumber         String?
  source            String?
  ownedById         String?
  isActive          Boolean            @default(true)
  lastContactedAt   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner               User?              @relation("OwnedCustomers", fields: [ownedById], references: [id], onDelete: SetNull)
  interests           ProductInterest[]
  categoryInterests   CategoryInterest[]
  timelineEntries     Note[]
  tasks               FollowUpTask[]
  quotes               Quote[]
  outreachRecipients   OutreachRecipient[]
  attributeInterests   CustomerAttributeInterest[]

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([ownedById])
  @@index([source])
}

model CategoryInterest {
  id          String          @id @default(cuid())
  customerId  String
  categoryId  String
  stage       InterestStage   @default(INTERESTED)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById String?
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation("CreatedCategoryInterests", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([customerId, categoryId])
  @@index([customerId])
  @@index([categoryId])
}

model ProductInterest {
  id              String           @id @default(cuid())
  customerId      String
  productId       String
  quantity        Int              @default(1) @map("quantityRequested")
  quotedPrice     Decimal?
  currency        String           @default("TRY")
  stage           InterestStage    @default(INTERESTED)
  interestNotes   String?          @map("note")
  targetPrice     Decimal?
  priority        InterestPriority @default(NORMAL)
  status          InterestStatus   @default(NEW)
  followUpAt      DateTime?
  lastContactedAt DateTime?
  closedAt        DateTime?
  source          String?
  createdById     String?
  assignedToId    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("CreatedInterests", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("AssignedInterests", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes           Note[]

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([priority])
  @@index([followUpAt])
  @@index([stage])
}

model Note {
  id          String           @id @default(cuid())
  content     String
  type        NoteType         @default(NOTE)
  customerId  String?
  productId   String?
  interestId  String?
  createdById String?
  createdAt   DateTime         @default(now())
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  interest    ProductInterest? @relation(fields: [interestId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([productId])
  @@index([interestId])
  @@index([createdAt])
}

model FollowUpTask {
  id           String       @id @default(cuid())
  title        String
  description  String?      @map("details")
  dueDate      DateTime?    @map("dueAt")
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  completedAt  DateTime?
  customerId   String?
  productId    String?
  assignedToId String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([priority])
}

model Quote {
  id            String      @id @default(cuid())
  customerId    String
  quoteNumber   String      @unique
  status        QuoteStatus @default(DRAFT)
  notes         String?
  paymentTerms  String?
  deliveryTerms String?
  warrantyTerms String?
  validityDate  DateTime?
  sentAt        DateTime?
  currencyMode  QuoteCurrencyMode @default(TRY)
  exchangeRate  Decimal?
  subtotal      Decimal     @default(0)
  discountTotal Decimal     @default(0)
  taxTotal      Decimal     @default(0)
  total         Decimal     @default(0)
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items              QuoteItem[]
  outreachRecipients OutreachRecipient[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([validityDate])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal
  currency    String   @default("TRY")
  discount    Decimal  @default(0)
  tax         Decimal  @default(0)
  total       Decimal  @default(0)
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
}

// Phase 18 — Quote Templates
model QuoteTemplate {
  id            String              @id @default(cuid())
  name          String
  description   String?
  paymentTerms  String?
  deliveryTerms String?
  warrantyTerms String?
  notes         String?
  currencyMode  QuoteCurrencyMode   @default(TRY)
  isActive      Boolean             @default(true)
  createdById   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdBy     User?               @relation("TemplatesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  items         QuoteTemplateItem[]

  @@index([isActive])
  @@index([createdAt])
}

model QuoteTemplateItem {
  id          String        @id @default(cuid())
  templateId  String
  productId   String?
  description String
  quantity    Int           @default(1)
  unitPrice   Decimal
  currency    String        @default("TRY")
  discount    Decimal       @default(0)
  tax         Decimal       @default(20)
  sortOrder   Int           @default(0)
  template    QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  product     Product?      @relation("TemplateItems", fields: [productId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([productId])
}

model OutreachCampaign {
  id          String              @id @default(cuid())
  productId   String?
  categoryId  String?
  message     String
  offerText   String?
  price       Decimal?
  currency    String              @default("TRY")
  status      OutreachStatus      @default(DRAFT)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  product     Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  category    ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?               @relation("CreatedCampaigns", fields: [createdById], references: [id], onDelete: SetNull)
  recipients  OutreachRecipient[]

  @@index([productId])
  @@index([categoryId])
  @@index([createdAt])
}

// Phase 11 — XML Inventory Sync
model XmlSyncSource {
  id          String       @id @default(cuid())
  name        String
  url         String
  isEnabled   Boolean      @default(true)
  authHeader  String?
  lastSyncAt  DateTime?
  lastStatus  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  logs        XmlSyncLog[]
}

model XmlSyncLog {
  id             String        @id @default(cuid())
  sourceId       String
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  status         XmlSyncStatus @default(RUNNING)
  recordsFound   Int           @default(0)
  recordsCreated Int           @default(0)  // Phase 11A: new products created from XML
  recordsUpdated Int           @default(0)
  recordsSkipped Int           @default(0)
  errorMessage   String?
  source         XmlSyncSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([startedAt])
}

// Phase 10 — Capital Allocation Engine (admin-only)
model CapitalConfig {
  id                    String   @id @default(cuid())
  totalCapitalTry       Decimal
  reservePct            Decimal  @default(20)
  desiredTurnoverMonths Decimal  @default(3)
  updatedAt             DateTime @updatedAt
  updatedById           String?
  updatedBy             User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// Phase 12 — Marketplace Listing Registry
model MarketplaceListing {
  id                String              @id @default(cuid())
  productId         String
  platform          MarketplacePlatform
  platformListingId String?
  listingUrl        String?
  listingBarcode    String?
  listingSku        String?
  listingTitle      String?
  status            ListingStatus       @default(UNKNOWN)
  lastCheckedAt     DateTime?
  notes             String?
  responsibleId     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  product           Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  responsible       User?               @relation("ListingResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([platform])
  @@index([status])
  @@index([responsibleId])
}

// Phase 16 — Marketplace Product Mapping Engine
// Maps one or more marketplace identities to a single internal product.
// Multiple rows can point to the same productId (many-to-one design).
// Uniqueness enforced per (platform, platformBarcode) to prevent split-brain mappings.
model MarketplaceProductMapping {
  id                String              @id @default(cuid())
  platform          MarketplacePlatform
  platformProductId String?
  platformListingId String?
  platformBarcode   String?
  platformSku       String?
  platformTitle     String?
  productId         String
  confidence        String              @default("MANUAL") // MANUAL | BARCODE | SKU | LISTING
  isManual          Boolean             @default(true)
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  product           Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy         User?               @relation("MappingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([platform])
  @@index([productId])
  @@index([platform, platformBarcode])
  @@index([platform, platformSku])
  @@index([platform, platformListingId])
}

// Phase 16 — Audit log for customer question actions (answer sent to Trendyol)
model MarketplaceQuestionActionLog {
  id             String   @id @default(cuid())
  platform       String   @default("TRENDYOL")
  questionId     String
  actionType     String   @default("ANSWERED")
  answerText     String?
  userId         String?
  responseStatus String   // SUCCESS | ERROR
  errorMessage   String?
  createdAt      DateTime @default(now())
  user           User?    @relation("QuestionActionUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([platform])
  @@index([userId])
  @@index([createdAt])
}

// Phase 16 — Audit log for return claim actions (approve / issue created)
model MarketplaceReturnActionLog {
  id             String   @id @default(cuid())
  platform       String   @default("TRENDYOL")
  claimId        String
  claimItemId    String?
  actionType     String   // APPROVED | ISSUE_CREATED
  reasonCode     String?
  note           String?
  userId         String?
  responseStatus String   // SUCCESS | ERROR
  errorMessage   String?
  createdAt      DateTime @default(now())
  user           User?    @relation("ReturnActionUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([platform])
  @@index([userId])
  @@index([createdAt])
}

// Phase 16 — Historical monthly USD/TRY exchange rates for profit calculation
// Phase 31 — Added rmbUsdRate for RMB-first import formula
model MonthlyExchangeRate {
  id         String   @id @default(cuid())
  year       Int
  month      Int      // 1–12
  usdTryRate Decimal
  rmbUsdRate Decimal? @db.Decimal(12,4) // RMB per 1 USD (e.g. 7.25)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

// Phase 14 — Trendyol API Integration (singleton config row)
model TrendyolConfig {
  id          String    @id @default("singleton")
  supplierId  String    @default("")
  apiKey      String    @default("")
  apiSecret   String    @default("")
  isEnabled   Boolean   @default(false)
  lastSyncAt  DateTime?
  updatedAt   DateTime  @updatedAt
}

model OutreachRecipient {
  id         String           @id @default(cuid())
  campaignId String
  customerId String
  phone      String?
  status     RecipientStatus  @default(PENDING)
  sentAt     DateTime?
  repliedAt  DateTime?
  quoteId    String?
  wonAmount  Decimal?
  createdAt  DateTime         @default(now())
  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quote      Quote?           @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
  @@index([quoteId])
}

// Phase 11A — Product multi-image support
// sortOrder 0 = primary image (maps to resim1), 1-4 = resim2-5
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  sortOrder Int     @default(0)  // 0=primary
  source    String  @default("XML")  // XML | MANUAL
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([productId])
}

// Phase 11A — XML source data snapshot per product (one row per product)
// Stores raw XML feed values without polluting the Product master record.
// These are informational; IOTOMASYON product fields are the business truth.
model XmlProductData {
  id                     String    @id @default(cuid())
  productId              String    @unique  // one row per product
  sourceId               String?            // which XmlSyncSource produced this
  xmlSku                 String             // urun_kodu
  xmlName                String?            // urun_ismi
  xmlBrand               String?            // marka
  xmlUrunTipi            String?            // urun_tipi (informational, not business truth)
  xmlCurrencyType        String?            // CurrencyType (USD/TRY)
  xmlKdv                 Decimal?           // KDV rate
  xmlDateChange          String?            // date_change raw string
  xmlDateAdd             String?            // date_add raw string
  xmlAnaUrunKodu         String?            // ana_urun_kodu (parent product code)
  // USD-denominated marketplace prices from XML
  xmlPrice4              Decimal?           // base price (price4)
  xmlTrendyolPrice       Decimal?           // trendyol_salePrice
  xmlHbPrice             Decimal?           // hb_price
  xmlAmazonPrice         Decimal?           // amazon_price
  xmlPazaramaPrice       Decimal?           // pazarama_salePrice
  xmlIdefixPrice         Decimal?           // idefix_sale_price
  xmlBayiPrice           Decimal?           // bayi (dealer)
  xmlKoctasPrice         Decimal?           // koctas
  xmlTeknosaPrice        Decimal?           // teknosa_sale_price
  xmlTemuPrice           Decimal?           // temu_sale_price
  // Textual content
  xmlDescription         String?            // aciklama
  // Image URLs (preserved for reference even if ProductImage table is used)
  xmlImage1              String?
  xmlImage2              String?
  xmlImage3              String?
  xmlImage4              String?
  xmlImage5              String?
  // Sync tracking
  firstSeenAt            DateTime  @default(now())
  lastSeenAt             DateTime  @default(now())
  missingFromLatestFeed  Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  product                Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([xmlSku])
  @@index([lastSeenAt])
  @@index([missingFromLatestFeed])
}

// ─── Phase 20 — Supplier Intelligence ────────────────────────────────────────

model Supplier {
  id              String    @id @default(cuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  countryOfOrigin String?   // e.g. "CN", "TR", "DE"
  paymentTerms    String?   // free text: "NET 30", "Peşin", etc.
  defaultLeadDays Int?      // default lead time in days for this supplier
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products SupplierProduct[]

  @@index([name])
  @@index([isActive])
}

// One row per (supplier, product) pair.
// leadDays / unitCostUsd override the supplier-level defaults for this specific product.
model SupplierProduct {
  id           String   @id @default(cuid())
  supplierId   String
  productId    String
  unitCostUsd  Decimal?  // supplier price for this product in USD
  moq          Int?      // minimum order quantity
  leadDays     Int?      // lead time override for this product (days)
  isPreferred  Boolean  @default(false)  // preferred supplier for this product
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
  @@index([isPreferred])
}

// ─── Phase 26 — Product Performance Ranking ───────────────────────────────────
// One row per Trendyol order line. Synced via /admin/product-performance.
// productId is nullable: unmatched lines kept for audit but excluded from rankings.

model TrendyolSalesRecord {
  id           String   @id @default(cuid())
  orderId      String   // Trendyol order numeric ID (as string)
  lineId       BigInt   // order line ID — Trendyol uses int64, exceeds PostgreSQL INT range
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  orderDate      DateTime
  status         String   // e.g. "Delivered", "Cancelled", "Picking"
  merchantSku    String?
  barcode        String?
  productName    String
  quantity       Int
  unitPriceTry   Decimal  @db.Decimal(15,2)  // discountedPrice per unit
  totalPriceTry  Decimal  @db.Decimal(15,2)  // quantity × discountedPrice
  syncedAt       DateTime @default(now())

  @@unique([orderId, lineId])
  @@index([productId])
  @@index([orderDate])
  @@index([merchantSku])
  @@index([barcode])
}

// ─── Phase 29 — Order Ledger and Return Claims ────────────────────────────────
// One row per Trendyol claim × order-line pair.
// claimId+orderLineId is the natural unique key from the Trendyol claims API.
// productId is nullable: unmatched claims kept for audit.

model TrendyolReturnRecord {
  id            String   @id @default(cuid())
  claimId       String   // Trendyol claim ID (string)
  orderLineId   Int      // Trendyol order line ID within the claim
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  orderNumber   String   // Trendyol order number (display string)
  orderDate     DateTime // original order date
  claimDate     DateTime // when the return claim was opened
  status        String   // claimItemStatus.name e.g. "Accepted", "WaitingForArrival"
  reasonName    String?  // Turkish reason from customerClaimItemReason.name
  reasonCode    String?  // reason code

  productName   String
  barcode       String?
  merchantSku   String?
  unitPriceTry  Decimal  @db.Decimal(15,2) @default(0)
  syncedAt      DateTime @default(now())

  @@unique([claimId, orderLineId])
  @@index([productId])
  @@index([claimDate])
  @@index([orderNumber])
  @@index([status])
}
// Phase 30 — Marketplace Margin Policy Normalization
// Stores per-platform standard shipping cost and commission rate.
// Resolution order (highest priority first):
//   1. product.shippingCostOverride  / product.marketplaceCommissionOverride
//   2. product.shippingCost          / product.marketplaceCommission  (product-level)
//   3. MarketplacePlatformPolicy     (platform-level standard)
//   4. system default (shipping=0, commission=20%)

model MarketplacePlatformPolicy {
  id                    String              @id @default(cuid())
  platform              MarketplacePlatform @unique
  standardShippingTry   Decimal             @default(0)  @db.Decimal(10,2)
  standardCommissionPct Decimal             @default(20) @db.Decimal(5,2)
  paymentFeePct         Decimal             @default(0)  @db.Decimal(5,2)
  returnReservePct      Decimal             @default(0)  @db.Decimal(5,2)
  vatPct                Decimal             @default(20) @db.Decimal(5,2)
  notes                 String?
  updatedAt             DateTime            @updatedAt
  updatedById           String?
  updatedBy             User?               @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([platform])
}
