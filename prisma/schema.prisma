generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum InterestStatus {
  NEW
  WAITING_STOCK
  CONTACTED
  QUOTED
  WON
  LOST
  CANCELLED
}

enum InterestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum CustomerStatus {
  NEW
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum InterestStage {
  INTERESTED
  PRICE_SENT
  NEGOTIATING
  WAITING
  ORDERED
  CANCELLED
}

enum NoteType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
  QUOTE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String
  role             UserRole          @default(ADMIN)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productsCreated  Product[]         @relation("CreatedProducts")
  notesCreated     Note[]
  interestsCreated ProductInterest[] @relation("CreatedInterests")
  interestsOwned   ProductInterest[] @relation("AssignedInterests")
  tasksCreated     FollowUpTask[]    @relation("CreatedTasks")
  tasksOwned       FollowUpTask[]    @relation("AssignedTasks")
}

model Product {
  id             String            @id @default(cuid())
  sku            String            @unique
  name           String
  category       String?
  brand          String?
  model          String?
  stockQuantity  Int               @default(0)
  minimumStock   Int               @default(0)
  location       String?
  description    String?
  isActive       Boolean           @default(true)
  createdById    String?
  createdBy      User?             @relation("CreatedProducts", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  interests      ProductInterest[]
  notes          Note[]
  tasks          FollowUpTask[]

  @@index([name])
  @@index([category])
  @@index([stockQuantity, minimumStock])
}

model Customer {
  id           String            @id @default(cuid())
  name         String
  phone        String?
  whatsapp     String?
  email        String?
  company      String?
  status       CustomerStatus    @default(NEW)
  country      String?
  customerNotes String?          @map("notes")
  customerType String?
  city         String?
  district     String?
  address      String?
  taxOffice    String?
  taxNumber    String?
  source       String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  interests    ProductInterest[]
  timelineEntries Note[]
  tasks        FollowUpTask[]

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([status])
}

model ProductInterest {
  id              String           @id @default(cuid())
  customerId      String
  productId       String
  quantity        Int              @default(1) @map("quantityRequested")
  quotedPrice     Decimal?
  currency        String           @default("TRY")
  stage           InterestStage    @default(INTERESTED)
  interestNotes   String?          @map("note")
  targetPrice     Decimal?
  priority        InterestPriority @default(NORMAL)
  status          InterestStatus   @default(NEW)
  followUpAt      DateTime?
  lastContactedAt DateTime?
  closedAt        DateTime?
  source          String?
  createdById     String?
  assignedToId    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("CreatedInterests", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("AssignedInterests", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes           Note[]

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([priority])
  @@index([followUpAt])
  @@index([stage])
}

model Note {
  id          String           @id @default(cuid())
  content     String
  type        NoteType         @default(NOTE)
  customerId  String?
  productId   String?
  interestId  String?
  createdById String?
  createdAt   DateTime         @default(now())
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  interest    ProductInterest? @relation(fields: [interestId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([productId])
  @@index([interestId])
  @@index([createdAt])
}

model FollowUpTask {
  id           String       @id @default(cuid())
  title        String
  description  String?      @map("details")
  dueDate      DateTime?    @map("dueAt")
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  completedAt  DateTime?
  customerId   String?
  productId    String?
  assignedToId String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([priority])
}
